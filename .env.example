# Copy to .env and fill in. .env is gitignored; never commit real secrets.

# Database — shared by api, outbox relay and subscribers
DB_USER=eventify
DB_PASSWORD=eventify
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eventify
DB_SSLMODE=disable

# Message bus — outbox relay publishes, subscribers consume
AMQP_URI=amqp://guest:guest@localhost:5672/

# Outbox relay tuning
OUTBOX_POLL_INTERVAL=1s
OUTBOX_BATCH_SIZE=100

# JWT — no default; the process refuses to start without it
JWT_SECRET=your_jwt_secret_key_here

# Servers
HTTP_PORT=3000
GRPC_PORT=3002
GRAPHQL_PORT=8080

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

ENV=development # development, staging, production
