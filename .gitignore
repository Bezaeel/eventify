# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/
dist/

# Test + coverage output
*.test
*.out
coverage.html

# Dependency directories
vendor/

# Editors / OS
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Environment files — never commit secrets. .env.example IS committed.
.env
.env.local
.env.*.local

# Generated API docs. Note the trailing components: the previous blanket
# `docs/` rule also ignored docs/scripts/add_xtags.go and docs/telemetry.md,
# which are hand-written sources, not generated output. Combined with
# `make clean` running `rm -rf docs`, those files existed only on one laptop
# and were one `make clean` away from being lost permanently.
api/docs/docs.go
api/docs/swagger.json
api/docs/swagger.yaml

# Logs
*.log

# Air live reload
tmp/
temp/

# Local database files
*.db
*.sqlite

# go.work IS committed: it defines the module graph and every cross-module
# `replace` depends on it being consistent across machines. Only the local
# resolution cache is ignored.
go.work.sum
